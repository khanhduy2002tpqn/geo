# ─────────────────────────────────────────────────────────────
# GeoGebra Voice Tutor — environment variables
# Copy to `.env.local` for local development:  cp .env.example .env.local
# Turso is required for the main Geometry AI Studio shape library.
# AI, TTS, and admin credentials are optional feature flags.
# ─────────────────────────────────────────────────────────────

# --- AI explanations — any OpenAI-compatible provider ---
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Google Cloud Text-to-Speech (REST, API-key auth) ---
# Create an API key restricted to the "Cloud Text-to-Speech API":
#   https://console.cloud.google.com/apis/credentials
GOOGLE_TTS_API_KEY=
TTS_VOICE=vi-VN-Neural2-A
TTS_LANGUAGE=vi-VN

# --- Optional key used only by content-maintenance scripts ---
DEEPSEEK_API_KEY=

# --- Geometry AI Studio data (required for the main page) ---
TURSO_URL=
TURSO_AUTH_TOKEN=

# --- Admin (/admin) — HTTP Basic Auth (required to access the admin panel) ---
ADMIN_USERNAME=
ADMIN_PASSWORD=

# ─────────────────────────────────────────────────────────────
# GeoGebra Voice Tutor — environment variables
# Copy to `.env.local` for local development:  cp .env.example .env.local
# Everything is OPTIONAL in Phase 1:
#   - No GOOGLE_TTS_API_KEY -> the app returns explanation TEXT only (no audio).
#   - No OPENROUTER_API_KEY  -> all explanations use deterministic local
#     Vietnamese templates (this is the Phase 1 default and is fully working).
# ─────────────────────────────────────────────────────────────

# --- AI explanations (Phase 2) — OpenRouter, OpenAI-compatible API ---
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Google Cloud Text-to-Speech (REST, API-key auth) ---
# Create an API key restricted to the "Cloud Text-to-Speech API":
#   https://console.cloud.google.com/apis/credentials
GOOGLE_TTS_API_KEY=
TTS_VOICE=vi-VN-Neural2-A
TTS_LANGUAGE=vi-VN

# --- Geometry AI Studio (/geo-ai) ---
DEEPSEEK_API_KEY=
TURSO_URL=
TURSO_AUTH_TOKEN=

# --- Admin (/admin) — HTTP Basic Auth (required to access the admin panel) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
